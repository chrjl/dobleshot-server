{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact",
  "description": "Contact detail objects",
  "type": "object",
  "properties": {
    "website": {
      "type": "string"
    },
    "profiles": {
      "description": "Social networking profiles",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "network": {
            "type": "string"
          },
          "handle": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        },
        "required": ["url"]
      }
    },
    "locations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "zipcode": {
            "type": "number",
            "minimum": 0,
            "maximum": 99999
          },
          "phone": {
            "type": "string"
          },
          "email": {
            "type": "string"
          }
        },
        "required": ["name"]
      }
    },
    "contacts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "zipcode": {
            "type": "number",
            "minimum": 0,
            "maximum": 99999
          },
          "phone": {
            "type": "string"
          },
          "email": {
            "type": "string"
          }
        },
        "required": ["name"]
      }
    }
  }
}
