{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Prices",
  "description": "Pricing information",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "description": {
        "type": "string"
      },
      "price": {
        "type": "number"
      },
      "quantity": {
        "type": "number"
      },
      "unit": {
        "type": "string"
      }
    },
    "required": ["description", "price", "quantity", "unit"]
  }
}
